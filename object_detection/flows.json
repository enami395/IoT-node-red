    {
        "id": "16914aada2411bef",
        "type": "function",
        "z": "8d08f7fd6b6d8ee8",
        "name": "function 1",
        "func": "let result = \"\";\n\n// 1. Si l'IA renvoie directement un mot (ex: \"dog\")\nif (typeof msg.payload === \"string\") {\n    result = \"Détecté : \" + msg.payload;\n} \n// 2. Si l'IA renvoie un tableau d'éléments\nelse if (Array.isArray(msg.payload) && msg.payload.length > 0) {\n    let objets = [];\n    for (let i = 0; i < msg.payload.length; i++) {\n        let item = msg.payload[i];\n        \n        // Si c'est un objet détaillé avec un score\n        if (item.class !== undefined) {\n            let nom = item.class;\n            let precision = item.score ? Math.round(item.score * 100) + \"%\" : \"\";\n            objets.push(nom + (precision ? \" (\" + precision + \")\" : \"\"));\n        } \n        // Si c'est juste un mot dans un tableau\n        else if (typeof item === \"string\") {\n            objets.push(item);\n        }\n    }\n    result = \"Détecté : \" + objets.join(\", \");\n} \n// 3. S'il n'y a rien\nelse {\n    result = \"Aucun objet détecté\";\n}\n\nmsg.payload = result;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
