    {
        "id": "30360b11135f641e",
        "type": "ui_template",
        "z": "8d08f7fd6b6d8ee8",
        "group": "39b66eaebd5bd9ab",
        "name": "",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<div style=\"padding: 10px; background-color: #f9f9f9; border-radius: 8px;\">\n    <label style=\"display: block; margin-bottom: 8px; font-weight: bold; color: #333;\">Choisir une image à analyser :</label>\n    <input type=\"file\" id=\"monImageInput\" accept=\"image/png, image/jpeg, image/jpg\" style=\"padding: 5px; border: 1px solid #ccc; background: white; width: 100%; box-sizing: border-box;\" />\n</div>\n\n<script>\n    (function(scope) {\n    setTimeout(function() {\n        var inputElement = document.getElementById('monImageInput');\n        if (inputElement) {\n            inputElement.addEventListener('change', function(e) {\n                var file = e.target.files[0];\n                if (!file) return;\n\n                var reader = new FileReader();\n                reader.onload = function(event) {\n                    // 1. On charge l'image en mémoire\n                    var img = new Image();\n                    img.onload = function() {\n                        \n                        // 2. On définit une taille raisonnable pour l'IA\n                        var MAX_WIDTH = 800;\n                        var MAX_HEIGHT = 800;\n                        var width = img.width;\n                        var height = img.height;\n\n                        if (width > height) {\n                            if (width > MAX_WIDTH) {\n                                height *= MAX_WIDTH / width;\n                                width = MAX_WIDTH;\n                            }\n                        } else {\n                            if (height > MAX_HEIGHT) {\n                                width *= MAX_HEIGHT / height;\n                                height = MAX_HEIGHT;\n                            }\n                        }\n\n                        // 3. On dessine l'image rétrécie sur une toile (canvas) invisible\n                        var canvas = document.createElement('canvas');\n                        canvas.width = width;\n                        canvas.height = height;\n                        var ctx = canvas.getContext('2d');\n                        ctx.drawImage(img, 0, 0, width, height);\n\n                        // 4. On la compresse en JPEG léger (0.8 = 80% de qualité)\n                        var dataUrl = canvas.toDataURL('image/jpeg', 0.8);\n                        \n                        // 5. On envoie enfin la version légère à Node-RED\n                        var base64Data = dataUrl.split(',')[1];\n                        scope.send({ payload: base64Data });\n                    };\n                    img.src = event.target.result;\n                };\n                reader.readAsDataURL(file);\n            });\n        }\n    }, 200);\n})(scope);\n</script>",
